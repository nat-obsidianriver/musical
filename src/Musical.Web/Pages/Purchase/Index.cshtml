@page
@model Musical.Web.Pages.Purchase.IndexModel
@{
    ViewData["Title"] = "Purchase";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
@if (Model.IsAuthenticated)
{
        <div class="card border-success">
            <div class="card-body text-center">
                <h3 class="card-title text-success">You Already Have Access</h3>
                <p class="card-text mt-3">You're signed in and have full access to Study Sax.</p>
                <a asp-page="/Index" class="btn btn-outline-primary mt-2">Browse Scores</a>
            </div>
        </div>
}
else
{
        <div class="card">
            <div class="card-body text-center">
                <h3 class="card-title">Study Sax &mdash; Full Access</h3>
                <p class="card-text mt-3">Get full access to all Study Sax features, including score uploads, annotations, and folder management.</p>
                <div class="my-4">
                    <span class="display-4 fw-bold">$30</span>
                    <span class="text-muted d-block">One-time payment</span>
                </div>
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <form method="post">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Purchase Now</button>
                </form>
                <p class="mt-3 text-muted small">After payment you'll create your account.</p>
            </div>
        </div>
}
    </div>
</div>
