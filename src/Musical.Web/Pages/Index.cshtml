@page
@model IndexModel
@{
    ViewData["Title"] = "StudySax — Learn from the Best";
    var grouped = Model.Scores
        .GroupBy(s => new { s.FolderId, s.FolderName, s.FolderColor, s.FolderUserId, s.FolderUserDisplayName, s.FolderUserBio, s.FolderUserHeadshotFileName })
        .OrderBy(g => g.Key.FolderName ?? "zzz");
}

@{
    var showLanding = User.Identity?.IsAuthenticated != true || Model.IsAdmin;
    var heroContent = Model.SiteContent.GetValueOrDefault("home-hero");
    var featureCards = new[] { "home-feature-1", "home-feature-2", "home-feature-3" };
    var ctaContent = Model.SiteContent.GetValueOrDefault("home-cta");
}

@if (showLanding)
{
    <!-- ===== LANDING PAGE (unauthenticated visitors + admin) ===== -->

    <!-- Hero -->
    <div class="@(Model.IsAdmin ? "editable-block" : "") text-center py-5 mb-4" style="background:linear-gradient(135deg,#e8f4fd 0%,#f0f8ff 100%);border-radius:12px;">
        @if (Model.IsAdmin)
        {
            <button class="edit-btn" data-slug="home-hero" data-title="@(heroContent?.Title ?? "Learn from the Best.<br/>Right on the Page.")" data-source="home-hero-content" onclick="openEditorFromBtn(this)">&#9998; Edit</button>
        }
        <img src="~/images/study-sax-logo.jpeg" alt="StudySax" style="height:80px;width:auto;border-radius:10px;margin-bottom:1.25rem;" />
        <h1 class="display-5 fw-bold mb-3" style="color:#1a1a1a;">@Html.Raw(heroContent?.Title ?? "Learn from the Best.<br/>Right on the Page.")</h1>
        <div id="home-hero-content" class="lead mb-4 mx-auto" style="max-width:600px;color:#444;">
            @Html.Raw(heroContent?.Content ?? "StudySax puts expert advice from America's top concert saxophonists directly inside your sheet music — as interactive annotations you can explore at your own pace.")
        </div>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-page="/Auth/Register" class="btn btn-primary btn-lg px-4">Get Started — $30</a>
            <a asp-page="/About" class="btn btn-outline-secondary btn-lg px-4">Learn More</a>
        </div>
        <p class="mt-3 small text-muted">One-time fee. No subscriptions.</p>
    </div>

    <!-- How it works -->
    <div class="row text-center g-4 mb-5">
        @{
            var defaultFeatures = new[]
            {
                new { Slug = "home-feature-1", Emoji = "🎼", Title = "Browse the Library", Text = "Access a curated collection of concert saxophone repertoire, selected and annotated by faculty saxophonists." },
                new { Slug = "home-feature-2", Emoji = "💡", Title = "Tap Any Highlight", Text = "Highlighted sections mark where a professor has advice. Tap to expand and read their insight on that exact passage." },
                new { Slug = "home-feature-3", Emoji = "🎷", Title = "Play Better", Text = "Get consistent, reputable guidance on technique, interpretation, and audition prep — from professors you can trust." },
            };
        }
        @foreach (var feature in defaultFeatures)
        {
            var fc = Model.SiteContent.GetValueOrDefault(feature.Slug);
            <div class="col-md-4">
                <div class="@(Model.IsAdmin ? "editable-block" : "") p-4 h-100" style="background:#fff;border-radius:10px;border:1px solid #e9ecef;">
                    @if (Model.IsAdmin)
                    {
                        <button class="edit-btn" data-slug="@feature.Slug" data-title="@(fc?.Title ?? feature.Title)" data-source="@(feature.Slug)-content" onclick="openEditorFromBtn(this)">&#9998; Edit</button>
                    }
                    <div style="font-size:2.5rem;margin-bottom:0.75rem;">@feature.Emoji</div>
                    <h3 class="h5 fw-semibold mb-2">@(fc?.Title ?? feature.Title)</h3>
                    <div id="@(feature.Slug)-content" class="text-muted small mb-0">
                        @Html.Raw(fc?.Content ?? feature.Text)
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Featured professors -->
    <div class="mb-5">
        <h2 class="h4 fw-semibold text-center mb-4">Faculty Contributors</h2>
        <div class="row row-cols-1 row-cols-md-3 g-3 justify-content-center">
            @{
                var professors = new[]
                {
                    new { Name = "Timothy McAllister", School = "University of Michigan" },
                    new { Name = "Otis Murphy", School = "Indiana University" },
                    new { Name = "Taimur Sullivan", School = "Northwestern University" },
                    new { Name = "Zach Shemon", School = "University of Kansas Conservatory" },
                    new { Name = "Dr. Bogert", School = "Ball State University" },
                };
            }
            @foreach (var prof in professors)
            {
                <div class="col">
                    <div class="d-flex align-items-center gap-3 p-3" style="background:#fff;border-radius:10px;border:1px solid #e9ecef;">
                        <div style="width:44px;height:44px;border-radius:50%;background:#87CEEB;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.25rem;">🎷</div>
                        <div>
                            <div class="fw-semibold small">@prof.Name</div>
                            <div class="text-muted" style="font-size:0.8rem;">@prof.School</div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <p class="text-center text-muted small mt-3">More professors added regularly.</p>
    </div>

    <!-- Who it's for -->
    <div class="@(Model.IsAdmin ? "editable-block" : "") p-4 mb-5 text-center" style="background:#fff;border-radius:12px;border:1px solid #e9ecef;">
        @if (Model.IsAdmin)
        {
            <button class="edit-btn" data-slug="home-cta" data-title="@(ctaContent?.Title ?? "Built for Serious Students")" data-source="home-cta-content" onclick="openEditorFromBtn(this)">&#9998; Edit</button>
        }
        <h2 class="h4 fw-semibold mb-3">@(ctaContent?.Title ?? "Built for Serious Students")</h2>
        <div id="home-cta-content" class="text-muted mb-4 mx-auto" style="max-width:580px;">
            @Html.Raw(ctaContent?.Content ?? "StudySax is designed for high school and college saxophonists who want reputable, specific guidance — not a gamble on who you'll find online. Whether you're prepping for an audition or deepening your understanding of a piece, StudySax gives you a direct line to professors at the nation's top conservatories.")
        </div>
        <a asp-page="/Auth/Register" class="btn btn-primary px-4">Join for $30 — One Time</a>
    </div>
}

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- ===== SCORE LIBRARY (authenticated users) ===== -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Sheet Music Library</h1>
        <a asp-page="/Scores/Upload" class="btn btn-primary">+ Upload Score</a>
    </div>

    @if (!Model.Scores.Any())
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">No scores uploaded yet.</p>
            <a asp-page="/Scores/Upload" class="btn btn-outline-primary">Upload the first one</a>
        </div>
    }
    else
    {
        @foreach (var group in grouped)
        {
            var folderColor = group.Key.FolderColor ?? "#87CEEB";
            <div class="mb-5">
                @if (group.Key.FolderName is not null)
                {
                    <div class="mb-3 pb-2 border-bottom">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span style="width:14px;height:14px;border-radius:50%;background:@folderColor;display:inline-block;flex-shrink:0;"></span>
                            <h2 class="h5 mb-0 fw-semibold">@group.Key.FolderName</h2>
                            <span class="text-muted small">(@group.Count() score@(group.Count() == 1 ? "" : "s"))</span>
                        </div>
                        @if (group.Key.FolderUserId is not null && (group.Key.FolderUserHeadshotFileName is not null || !string.IsNullOrWhiteSpace(group.Key.FolderUserBio) || group.Key.FolderUserDisplayName is not null))
                        {
                            <div class="d-flex align-items-center gap-3 mt-2">
                                @if (group.Key.FolderUserHeadshotFileName is not null)
                                {
                                    <img src="@Model.ApiBase/api/users/@group.Key.FolderUserId/headshot"
                                         alt="@group.Key.FolderUserDisplayName"
                                         class="rounded-circle"
                                         style="width:48px;height:48px;object-fit:cover;flex-shrink:0;" />
                                }
                                <div>
                                    @if (group.Key.FolderUserDisplayName is not null)
                                    {
                                        <div class="fw-semibold small">@group.Key.FolderUserDisplayName</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(group.Key.FolderUserBio))
                                    {
                                        <div class="text-muted small">@group.Key.FolderUserBio</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 mb-3 pb-2 border-bottom">
                        <h2 class="h5 mb-0 fw-semibold text-muted">Uncategorized</h2>
                        <span class="text-muted small">(@group.Count() score@(group.Count() == 1 ? "" : "s"))</span>
                    </div>
                }

                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var score in group)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm">
                                <a asp-page="/Scores/Detail" asp-route-id="@score.Id">
                                    <img src="@Model.ApiBase/api/scores/@score.Id/image"
                                         class="card-img-top"
                                         alt="@score.Title"
                                         style="height:180px;object-fit:cover;" />
                                </a>
                                <div class="card-body">
                                    <h5 class="card-title">@score.Title</h5>
                                    @if (!string.IsNullOrEmpty(score.Composer))
                                    {
                                        <p class="card-text text-muted small mb-1">@score.Composer</p>
                                    }
                                    @if (!string.IsNullOrEmpty(score.Description))
                                    {
                                        <p class="card-text small">@score.Description</p>
                                    }
                                </div>
                                <div class="card-footer d-flex justify-content-between align-items-center">
                                    <small class="text-muted">@score.AnnotationCount annotation(s)</small>
                                    <a asp-page="/Scores/Detail" asp-route-id="@score.Id"
                                       class="btn btn-sm btn-outline-secondary">View &amp; Annotate</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
}

@if (Model.IsAdmin)
{
    <partial name="_InlineEditor" />

    @section Scripts {
        <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
        <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
        <script>
            window.__apiBase = "@(ViewContext.HttpContext.RequestServices.GetRequiredService<IConfiguration>()["ApiBaseUrl"] ?? "http://localhost:5241")";
            window.__jwt = "@Model.JwtToken";
        </script>
        <partial name="_InlineEditorScripts" />
    }
}
