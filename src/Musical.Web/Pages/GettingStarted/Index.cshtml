@page
@model Musical.Web.Pages.GettingStarted.IndexModel
@{
    ViewData["Title"] = "Getting Started";
}

<h1 class="mb-4">Getting Started</h1>

@if (!string.IsNullOrEmpty(Model.VideoEmbedUrl))
{
    <div class="ratio ratio-16x9 mb-4" style="max-width:900px;">
        <iframe src="@Model.VideoEmbedUrl"
                title="Getting Started Tutorial"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
        </iframe>
    </div>
}
else if (!string.IsNullOrEmpty(Model.VideoFileUrl))
{
    <div class="mb-4" style="max-width:900px;">
        <video controls class="w-100 rounded">
            <source src="@Model.VideoFileUrl" />
            Your browser does not support the video tag.
        </video>
    </div>
}
else
{
    <div class="alert alert-info">
        A tutorial video is coming soon. Check back later!
    </div>
}
