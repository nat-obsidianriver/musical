@page
@model Musical.Web.Pages.About.CreatorModel
@{
    ViewData["Title"] = "About the Creator";
    var creatorContent = Model.SiteContent.GetValueOrDefault("about-creator");
}

<div class="row justify-content-center">
    <div class="col-md-8">

        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/About">About StudySax</a></li>
                <li class="breadcrumb-item active" aria-current="page">About the Creator</li>
            </ol>
        </nav>

        <h1 class="h2 mb-4">About the Creator</h1>

        <div class="@(Model.IsAdmin ? "editable-block" : "")">
            @if (Model.IsAdmin)
            {
                <button class="edit-btn" data-slug="about-creator" data-title="@(creatorContent?.Title ?? "About the Creator")" data-source="about-creator-content" onclick="openEditorFromBtn(this)">&#9998; Edit</button>
            }
            <div id="about-creator-content">
                @if (creatorContent is not null)
                {
                    @Html.Raw(creatorContent.Content)
                }
                else
                {
                    <p class="lead text-muted fst-italic">
                        Creator bio coming soon.
                    </p>
                }
            </div>
        </div>

        <div class="mt-5">
            <a asp-page="/About" class="btn btn-outline-secondary">&larr; Back to About</a>
            <a asp-page="/Contact" class="btn btn-outline-secondary ms-2">Get in Touch</a>
        </div>

    </div>
</div>

@if (Model.IsAdmin)
{
    <partial name="_InlineEditor" />

    @section Scripts {
        <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
        <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
        <script>
            window.__apiBase = "@Model.ApiBase";
            window.__jwt = "@Model.JwtToken";
        </script>
        <partial name="_InlineEditorScripts" />
    }
}
